local Players = game:GetService("Players")

-- SECURITY: Add authorized Roblox User IDs here so random players cannot use it
local ALLOWED_USERS = {
	[12345678] = true -- CHANGE THIS to your actual Roblox User ID
}

-- Function to build the visual interface automatically for an authorized admin
local function createExecutorUI(player)
	local playerGui = player:WaitForChild("PlayerGui")
	
	-- Main Screen Container
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "AdminExecutorGui"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = playerGui
	
	-- Background Panel
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, 350, 0, 220)
	frame.Position = UDim2.new(0.5, -175, 0.4, -110)
	frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	frame.BorderSizePixel = 0
	frame.Active = true
	frame.Draggable = true -- Allows you to move the window around the screen
	frame.Parent = screenGui
	
	-- Title Bar
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, 30)
	title.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	title.Text = "  Server Script Executor"
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Font = Enum.Font.SourceSansBold
	title.TextSize = 16
	title.Parent = frame
	
	-- Code Input Box (Where you type your scripts)
	local scriptInput = Instance.new("TextBox")
	scriptInput.Size = UDim2.new(1, -20, 1, -85)
	scriptInput.Position = UDim2.new(0, 10, 0, 40)
	scriptInput.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	scriptInput.TextColor3 = Color3.fromRGB(255, 255, 255)
	scriptInput.Text = "-- Type your Lua code here\nprint('Hello World!')"
	scriptInput.ClearTextOnFocus = false
	scriptInput.MultiLine = true
	scriptInput.TextXAlignment = Enum.TextXAlignment.Left
	scriptInput.TextYAlignment = Enum.TextYAlignment.Top
	scriptInput.Font = Enum.Font.Code
	scriptInput.TextSize = 14
	scriptInput.Parent = frame
	
	-- Execute Button
	local executeButton = Instance.new("TextButton")
	executeButton.Size = UDim2.new(1, -20, 0, 35)
	executeButton.Position = UDim2.new(0, 10, 1, -45)
	executeButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
	executeButton.Text = "Execute Script"
	executeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	executeButton.Font = Enum.Font.SourceSansBold
	executeButton.TextSize = 16
	executeButton.Parent = frame
	
	-- LocalScript inside the button to send code back to the server securely
	local clientScript = Instance.new("LocalScript")
	clientScript.Name = "ExecutionHandler"
	clientScript.Parent = executeButton
	
	-- We dynamically bind a RemoteEvent inside the script to pass data safely
	local remoteEvent = Instance.new("RemoteEvent")
	remoteEvent.Name = "RunCodeEvent"
	remoteEvent.Parent = clientScript
	
	-- Client-side button click logic
	clientScript.Source = [[
		local button = script.Parent
		local textbox = button.Parent:WaitForChild("ScriptInput")
		local event = script:WaitForChild("RunCodeEvent")
		
		button.MouseButton1Click:Connect(function()
			if textbox.Text ~= "" then
				event:FireServer(textbox.Text)
			end
		end)
	]]
	
	-- Server-side execution logic for this specific player's UI
	remoteEvent.OnServerEvent:Connect(function(firingPlayer, codeToExecute)
		-- Extra safety check: confirm the firing player is the authorized owner
		if firingPlayer ~= player or not ALLOWED_USERS[firingPlayer.UserId] then 
			warn("Unauthorized execution attempt rejected.")
			return 
		end
		
		print("Executing script from " .. firingPlayer.Name .. "...")
		
		-- Load and run the script safely
		local success, compiledFunc = pcall(loadstring, codeToExecute)
		if success and compiledFunc then
			local runSuccess, runError = pcall(compiledFunc)
			if not runSuccess then
				warn("Execution Error: " .. tostring(runError))
			end
		else
			warn("Syntax Error: " .. tostring(compiledFunc))
		end
	end)
end

-- Give the UI to authorized users when they load into the game
Players.PlayerAdded:Connect(function(player)
	if ALLOWED_USERS[player.UserId] then
		player.CharacterAdded:Connect(function()
			-- Small delay ensures PlayerGui is completely ready
			task.wait(1) 
			createExecutorUI(player)
		end)
	end
end)

