-- Global execution framework for Delta environment
local function runCode(codeString)
    if codeString and codeString ~= "" then
        local success, err = pcall(function()
            -- Force check for delta/exploit level loadstring variables
            local exec = (getgenv and getgenv().loadstring) or loadstring
            task.spawn(assert(exec(codeString)))
        end)
        if not success then warn("Delta Console Error: " .. tostring(err)) end
    end
end

executeButton.MouseButton1Click:Connect(function() runCode(scriptInput.Text) end)
